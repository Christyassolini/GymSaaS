# ==============================================
# GymSaaS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ==============================================

# ----------------------------------------------
# Banco de Dados
# ----------------------------------------------
DATABASE_URL="mysql://root:password@localhost:3306/gymsaas"

# ----------------------------------------------
# Better Auth
# ----------------------------------------------
BETTER_AUTH_SECRET="gere-uma-chave-secreta-aqui-minimo-32-chars"
BETTER_AUTH_URL="http://localhost:3001"

# ----------------------------------------------
# API (Backend)
# ----------------------------------------------
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"

# ----------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ----------------------------------------------
# Cloudinary (uploads de mídia e fotos)
# ----------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ----------------------------------------------
# Resend (e-mails transacionais)
# ----------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@gymsaas.com.br"

# ----------------------------------------------
# Asaas (gateway de pagamento)
# ASAAS_ENVIRONMENT: "sandbox" para testes ou "production" para produção
# ----------------------------------------------
ASAAS_API_KEY=""
ASAAS_ENVIRONMENT="sandbox"

# ----------------------------------------------
# Meta API — WhatsApp Business
# ----------------------------------------------
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_VERIFY_TOKEN=""
META_WABA_ID=""
